+func transportOptions(cfg mobileConfig) transport.Options {
+	switch normalizeTransport(cfg.transport) {
+	case defaultTransport:
+		return vp8channel.Options{
+			FPS:       clampAtLeastOne(cfg.vp8FPS, 120),
+			BatchSize: clampAtLeastOne(cfg.vp8BatchSize, 64),
+		}
+	case "seichannel":
+		return seichannel.Options{
+			FPS:          cfg.seiFPS,
+			BatchSize:    cfg.seiBatchSize,
+			FragmentSize: cfg.seiFragmentSize,
+			AckTimeoutMS: cfg.seiAckTimeoutMS,
+		}
+	case "videochannel":
+		return videochannel.Options{
+			Width:      cfg.videoWidth,
+			Height:     cfg.videoHeight,
+			FPS:        cfg.videoFPS,
+			Bitrate:    cfg.videoBitrate,
+			HW:         cfg.videoHW,
+			QRSize:     cfg.videoQRSize,
+			QRRecovery: cfg.videoQRRecovery,
+			Codec:      cfg.videoCodec,
+			TileModule: cfg.videoTileModule,
+			TileRS:     cfg.videoTileRS,
+		}
+	default:
+		return nil
+	}
+}
+
+func transportOptionsForCheck(transportName string, vp8FPS, vp8BatchSize int) transport.Options {
+	if normalizeTransport(transportName) != defaultTransport {
+		return nil
+	}
+	return vp8channel.Options{
+		FPS:       clampAtLeastOne(vp8FPS, 120),
+		BatchSize: clampAtLeastOne(vp8BatchSize, 64),
+	}
+}
+
