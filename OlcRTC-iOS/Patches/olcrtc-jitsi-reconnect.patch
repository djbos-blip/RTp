+func (c *Client) openInitialSession(
+	ctx context.Context,
+	ln transport.Transport,
+) (*smux.Session, *smux.Stream, string, error) {
+	const (
+		maxAttempts  = 5
+		attemptDelay = 2 * time.Second
+	)
+
+	var lastErr error
+	for attempt := 1; attempt <= maxAttempts; attempt++ {
+		if attempt > 1 {
+			logger.Infof("initial handshake retry attempt=%d/%d", attempt, maxAttempts)
+		}
+
+		c.conn = muxconn.New(ln, c.cipher)
+		sess, err := smux.Client(c.conn, smuxConfig(linkMaxPayload(ln)))
+		if err != nil {
+			lastErr = fmt.Errorf("smux client: %w", err)
+		} else {
+			control, sid, err := openControlStreamTimeout(ctx, sess, c.deviceID, c.claims, 6*time.Second)
+			if err == nil {
+				return sess, control, sid, nil
+			}
+			lastErr = err
+			logger.Warnf("initial handshake failed (attempt %d/%d): %v", attempt, maxAttempts, err)
+			_ = sess.Close()
+		}
+
+		if c.conn != nil {
+			_ = c.conn.Close()
+		}
+		c.resetLinkPeer()
+
+		select {
+		case <-ctx.Done():
+			return nil, nil, "", ctx.Err()
+		case <-time.After(time.Duration(attempt) * attemptDelay):
+		}
+	}
+
+	if lastErr == nil {
+		lastErr = ErrConnectFailed
+	}
+	return nil, nil, "", lastErr
+}
+
 // openControlStream opens stream #1 on sess and performs the handshake.
 // The stream stays open for the lifetime of the smux session and carries
 // post-handshake control messages.
